# Apex Gadgets Email Support Agent — environment configuration

# Copy this file to `.env` and fill in real values there. `.env` is
# git-ignored and must never be committed — this file (.env.example)
# is the committed template with no real secrets in it.

# Matches the default credentials in docker-compose.yml. If you're
# pointing at your own already-running Postgres container instead,
# change this to match its user/password/port/db name.
DATABASE_URL=postgresql+psycopg2://apex:apex@localhost:5432/apex_gadgets

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21

AZURE_OPENAI_RELEVANCE_DEPLOYMENT=
AZURE_OPENAI_SENSITIVITY_DEPLOYMENT=
AZURE_OPENAI_SPECIALIST_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

PINECONE_API_KEY=
PINECONE_INDEX_NAME=

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SUPPORT_ADDRESS=

DASHBOARD_ADMIN_USERNAME=admin
DASHBOARD_ADMIN_PASSWORD=

ENVIRONMENT=local
LOG_LEVEL=INFO
